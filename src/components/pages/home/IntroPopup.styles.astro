<style is:global>
  .intro-popup__content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  .intro-popup__highlight {
    margin: 0;
    color: var(--token-text);
    line-height: 1.55;
  }

  .intro-popup__highlight strong {
    color: var(--token-primary);
    font-weight: 700;
  }

  .intro-popup__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2) var(--spacing-3);
    line-height: 1.5;
  }

  .intro-popup__list li {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2);
    color: var(--token-text-muted);
  }

  .intro-popup__list li:not(:last-child)::after {
    content: "•";
    color: color-mix(in srgb, var(--token-text-muted) 55%, transparent);
    margin-inline-start: var(--spacing-1);
  }

  .intro-popup__tech {
    overflow: hidden;
    margin: 0 calc(var(--spacing-5) * -1);
    mask-image: linear-gradient(
      90deg,
      transparent,
      var(--token-text) 10%,
      var(--token-text) 90%,
      transparent
    );
  }

  .intro-popup__tech-track {
    display: flex;
    width: max-content;
    animation: intro-tech-marquee 55s linear infinite;
  }

  html[dir="rtl"] .intro-popup__tech-track {
    animation-name: intro-tech-marquee-rtl;
  }

  .intro-popup__tech-group {
    display: flex;
    align-items: center;
    gap: var(--spacing-5);
    flex-shrink: 0;
    opacity: 0.25;
  }

  html[data-theme="dark"] .intro-popup__tech-group {
    opacity: 0.45;
  }

  .intro-popup__tech-item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 1.1rem;
    height: 1.1rem;
    color: var(--token-text-muted);
    transition: color 0.15s ease, opacity 0.15s ease;
  }

  .intro-popup__tech-item:hover {
    color: var(--token-primary);
    opacity: 1;
  }

  .intro-popup__tech-icon {
    display: inline-flex;
    width: 100%;
    height: 100%;
  }

  .intro-popup__tech-icon svg {
    width: 100%;
    height: 100%;
  }

  /* Brand SVGs use hardcoded fills — map to theme via monochrome filter */
  .intro-popup__tech-icon svg:not([fill="currentColor"]) {
    filter: brightness(0);
    transition: filter 0.15s ease, opacity 0.15s ease;
  }

  html[data-theme="dark"] .intro-popup__tech-icon svg:not([fill="currentColor"]) {
    filter: brightness(0) invert(1);
  }

  .intro-popup__tech-item:hover .intro-popup__tech-icon svg:not([fill="currentColor"]) {
    filter: brightness(0) sepia(1) saturate(4) hue-rotate(220deg);
    opacity: 1;
  }

  html[data-theme="dark"] .intro-popup__tech-item:hover .intro-popup__tech-icon svg:not([fill="currentColor"]) {
    filter: brightness(0) invert(1) sepia(1) saturate(4) hue-rotate(220deg);
  }
</style>
