---
import Card from "../../ui/card/Card.astro";
import Typography from "../../ui/typography/Typography.astro";
import ArticleCard from "../../ui/card/ArticleCard.astro";
import { HOME_ARTICLES_CONTENT } from "../../../assets/contents/pages/home/articles";
import { getContent } from "../../../lib/content/ui-text";
import type { ArticleSummary } from "../../../lib/content/articles";
import type { Locale } from "../../../i18n/config";

interface Props {
  lang: Locale;
  articles: ArticleSummary[];
}

const { lang, articles } = Astro.props as Props;
const content = getContent(HOME_ARTICLES_CONTENT, lang);
---

<section>
  <Typography as="h2" variant="headline" class="mb-4 text-3xl">{content.title}</Typography>
  {articles.length > 0 ? (
    <div class="grid gap-4">
      {articles.map((article) => (
        <ArticleCard
          title={article.title}
          date={article.publishedAt}
          excerpt={article.excerpt}
          href={`/${lang}/articles/${article.slug}`}
        />
      ))}
    </div>
  ) : (
    <Card interactive={false} padding="md" class="text-[var(--color-text-muted)]">
      {content.empty}
    </Card>
  )}
</section>
