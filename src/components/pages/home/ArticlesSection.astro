---
import Card from "../../ui/card/Card.astro";
import Typography from "../../ui/typography/Typography.astro";
import ArticleCard from "../../ui/card/ArticleCard.astro";
import Flex from "../../ui/layout/Flex.astro";
import Link from "../../ui/link/Link.astro";
import { HOME_ARTICLES_CONTENT } from "../../../assets/contents/pages/home/articles";
import { getContent } from "../../../lib/content/ui-text";
import type { ArticleItem } from "../../../lib/content/articles";
import type { Locale } from "../../../i18n/config";

interface Props {
  lang: Locale;
  articles: ArticleItem[];
}

const { lang, articles } = Astro.props as Props;
const content = getContent(HOME_ARTICLES_CONTENT, lang);
const articlesHref = `/${lang}/articles`;
const previewArticles = articles.slice(0, 2);
---

<section>
  <Flex justify="between" align="center" gap="md" class="mb-4">
    <Typography as="h2" variant="headline" class="text-3xl">{content.title}</Typography>
    <Link href={articlesHref} variant="unstyled" class="service-card__cta mt-0 shrink-0">
      {content.showMore}
    </Link>
  </Flex>

  {previewArticles.length > 0 ? (
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 md:gap-5">
      {previewArticles.map((article) => (
        <ArticleCard
          title={article.title}
          description={article.description}
          href={article.url}
          platform={article.platform}
          platformLabel={article.platformLabel}
          publishedAt={article.publishedAt}
        />
      ))}
    </div>
  ) : (
    <Card interactive={false} padding="md" class="text-text-muted">
      {content.empty}
    </Card>
  )}
</section>
