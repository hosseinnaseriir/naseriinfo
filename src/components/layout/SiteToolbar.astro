---
import Icon from "../ui/icon/Icon.astro";
import Link from "../ui/link/Link.astro";
import { TOOLBAR_CONTENT } from "../../assets/contents/common/toolbar";
import { getContent } from "../../lib/content/ui-text";
import { localeConfig, type Locale } from "../../i18n/config";

interface Props {
  locale: Locale;
  path: string;
  variant?: "anchored" | "fixed";
}

const { locale, path, variant = "fixed" } = Astro.props;
const content = getContent(TOOLBAR_CONTENT, locale);
const alternateLocale: Locale = locale === "fa" ? "en" : "fa";
const alternatePath = path.replace(/^\/(en|fa)/, `/${alternateLocale}`) || `/${alternateLocale}`;
const alternateLabel = localeConfig[alternateLocale].label;
---

<div
  class:list={[
    "flex items-center gap-1",
    variant === "anchored" && "self-start m-0",
    variant === "fixed" && "fixed top-3 end-3 z-50"
  ]}
>
  <button type="button" class="toolbar-btn" data-theme-toggle aria-label={content.themeToggle}>
    <Icon name="sun" class="toolbar-icon hidden dark:inline-flex" />
    <Icon name="moon" class="toolbar-icon hidden light:inline-flex" />
  </button>

  <Link href={alternatePath} variant="toolbar" ariaLabel={content.switchTo(alternateLabel)} external={false}>
    <Icon name="language" class="toolbar-icon" />
    <span class="text-[0.7rem] font-semibold tracking-wide">{alternateLocale.toUpperCase()}</span>
  </Link>
</div>
