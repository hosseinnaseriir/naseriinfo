<style is:global>
  .popup-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    width: 100%;
    max-width: 100vw;
    height: 100%;
    max-height: 100vh;
    margin: 0;
    padding: var(--space-4);
    border: none;
    background: transparent;
    color: var(--color-text);
    overflow: hidden;
  }

  .popup-modal:not([open]) {
    display: none;
  }

  .popup-modal[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .popup-modal::backdrop {
    background: var(--color-backdrop);
    backdrop-filter: blur(var(--backdrop-blur));
  }

  .popup-modal__panel {
    display: flex;
    flex-direction: column;
    width: min(36rem, 100%);
    max-height: min(85vh, 100%);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: var(--shadow-xl);
    animation: popup-panel-in 0.22s ease-out;
  }

  .popup-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }

  .popup-modal__title {
    margin: 0;
    font-size: var(--text-body1);
    font-weight: 600;
    line-height: 1.3;
  }

  .popup-modal__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
  }

  .popup-modal__close:hover {
    color: var(--color-text);
    background: var(--color-hover);
    border-color: color-mix(in srgb, var(--color-primary) 35%, var(--color-border));
  }

  .popup-modal__close-icon {
    width: 1rem;
    height: 1rem;
  }

  .popup-modal__body {
    padding: var(--space-5);
    overflow-y: auto;
    font-size: var(--text-body2);
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  .popup-modal__footer {
    display: none;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5) var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .popup-modal__footer:not(:empty) {
    display: flex;
  }

  .popup-modal__footer-actions {
    display: none;
    flex-direction: column;
    gap: var(--space-2);
  }

  .popup-modal__footer-actions a,
  .popup-modal__footer-actions button {
    width: 100%;
    justify-content: center;
  }

  @media (max-width: 767px) {
    .popup-modal__footer-actions {
      display: flex;
    }
  }

  @keyframes popup-panel-in {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.98);
    }

    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .popup-modal__panel {
      animation: none;
    }
  }
</style>
