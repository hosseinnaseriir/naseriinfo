<style is:global>
  .popup-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    width: 100%;
    max-width: 100vw;
    height: 100%;
    max-height: 100vh;
    margin: 0;
    padding: var(--spacing-4);
    border: none;
    background: transparent;
    color: var(--token-text);
    overflow: hidden;
  }

  .popup-modal:not([open]) {
    display: none;
  }

  .popup-modal[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .popup-modal::backdrop {
    background: var(--token-backdrop);
    backdrop-filter: blur(var(--token-backdrop-blur));
  }

  .popup-modal__panel {
    display: flex;
    flex-direction: column;
    width: min(36rem, 100%);
    max-height: min(85vh, 100%);
    border: 1px solid var(--token-border);
    border-radius: var(--radius-lg);
    background: var(--token-surface);
    box-shadow: var(--token-shadow-xl);
    animation: popup-panel-in 0.22s ease-out;
  }

  .popup-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-3);
    padding: var(--spacing-4) var(--spacing-5);
    border-bottom: 1px solid var(--token-border);
  }

  .popup-modal__title {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--token-text);
  }

  .popup-modal__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    padding: 0;
    border: 1px solid var(--token-border);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--token-text-muted);
    cursor: pointer;
    transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
  }

  .popup-modal__close:hover {
    color: var(--token-text);
    background: var(--token-hover);
    border-color: color-mix(in srgb, var(--token-primary) 35%, var(--token-border));
  }

  .popup-modal__close-icon {
    width: 1rem;
    height: 1rem;
  }

  .popup-modal__body {
    padding: var(--spacing-5);
    overflow-y: auto;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--token-text-muted);
  }

  @media (min-width: 768px) {
    .popup-modal__body {
      font-size: 1rem;
    }
  }

  .popup-modal__footer {
    display: none;
    flex-direction: column;
    gap: var(--spacing-4);
    padding: var(--spacing-4) var(--spacing-5) var(--spacing-5);
    border-top: 1px solid var(--token-border);
  }

  .popup-modal__footer:not(:empty) {
    display: flex;
  }

  .popup-modal__footer-actions {
    display: none;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .popup-modal__footer-actions a,
  .popup-modal__footer-actions button {
    width: 100%;
    justify-content: center;
  }

  @media (max-width: 767px) {
    .popup-modal__footer-actions {
      display: flex;
    }
  }
</style>
