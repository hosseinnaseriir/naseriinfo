---
import Icon from "../icon/Icon.astro";
import { POPUP_CONTENT } from "../../../assets/contents/common/popup";
import { getContent } from "../../../lib/content/ui-text";
import type { Locale } from "../../../i18n/config";
import PopupStyles from "./Popup.styles.astro";
import PopupScripts from "./Popup.scripts.astro";

interface Props {
  id: string;
  title: string;
  locale?: Locale;
}

const { id, title, locale = "en" } = Astro.props;
const content = getContent(POPUP_CONTENT, locale);
const titleId = `${id}-title`;
---

<dialog id={id} class="popup-modal" aria-labelledby={titleId}>
  <div class="popup-modal__panel" role="document">
    <header class="popup-modal__header">
      <h2 id={titleId} class="popup-modal__title">{title}</h2>
      <button type="button" class="popup-modal__close" data-close-popup={id} aria-label={content.close}>
        <Icon name="close" class="popup-modal__close-icon" />
      </button>
    </header>
    <div class="popup-modal__body">
      <slot />
    </div>
    <footer class="popup-modal__footer">
      <slot name="footer" />
    </footer>
  </div>
</dialog>

<PopupStyles />
<PopupScripts />
