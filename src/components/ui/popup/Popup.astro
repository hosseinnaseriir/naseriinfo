---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<dialog id={id} class="w-[min(34rem,90vw)] rounded-lg border border-[var(--color-border)] p-0 backdrop:bg-black/40">
  <div class="p-5">
    <div class="mb-3 flex items-center justify-between">
      <h3 class="text-xl font-semibold">{title}</h3>
      <button type="button" data-close-popup={id} class="rounded px-2 py-1 text-sm hover:bg-gray-100">Close</button>
    </div>
    <slot />
  </div>
</dialog>

<script>
  document.querySelectorAll("[data-open-popup]").forEach((button) => {
    button.addEventListener("click", () => {
      const id = button.getAttribute("data-open-popup");
      const dialog = id ? document.getElementById(id) : null;
      if (dialog && dialog instanceof HTMLDialogElement) dialog.showModal();
    });
  });

  document.querySelectorAll("[data-close-popup]").forEach((button) => {
    button.addEventListener("click", () => {
      const id = button.getAttribute("data-close-popup");
      const dialog = id ? document.getElementById(id) : null;
      if (dialog && dialog instanceof HTMLDialogElement) dialog.close();
    });
  });
</script>
