---
interface Props {
  id: string;
  label: string;
  placeholder?: string;
  type?: "text" | "email";
}

const { id, label, placeholder = "", type = "text" } = Astro.props;
---

<label for={id} class="flex flex-col gap-2">
  <span class="text-sm text-[var(--color-text-muted)]">{label}</span>
  <input
    id={id}
    name={id}
    type={type}
    placeholder={placeholder}
    class="rounded-md border border-[var(--color-border)] bg-white px-3 py-2 outline-none focus-visible:ring-2 focus-visible:ring-slate-500"
  />
</label>
