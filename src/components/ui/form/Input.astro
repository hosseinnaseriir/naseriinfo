---
interface Props {
  id: string;
  label: string;
  placeholder?: string;
  type?: "text" | "email";
  required?: boolean;
  autocomplete?: string;
}

const {
  id,
  label,
  placeholder = "",
  type = "text",
  required = false,
  autocomplete
} = Astro.props;
---

<label for={id} class="flex flex-col gap-2">
  <span class="text-sm text-text-muted">{label}</span>
  <input
    id={id}
    name={id}
    type={type}
    placeholder={placeholder}
    required={required}
    autocomplete={autocomplete}
    class="rounded-md border border-border bg-surface px-3 py-2 text-text outline-none focus-visible:ring-2 focus-visible:ring-primary/50"
  />
</label>
