---
interface Props {
  id: string;
  label: string;
}

const { id, label } = Astro.props;
---

<label for={id} class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)]">
  <input
    id={id}
    name={id}
    type="checkbox"
    class="h-4 w-4 rounded border border-[var(--color-border)] accent-slate-700"
  />
  <span>{label}</span>
</label>
