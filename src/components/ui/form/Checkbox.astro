---
interface Props {
  id: string;
  label: string;
}

const { id, label } = Astro.props;
---

<label for={id} class="inline-flex items-center gap-2 text-sm text-text-muted">
  <input
    id={id}
    name={id}
    type="checkbox"
    class="size-4 rounded border border-border accent-primary"
  />
  {label}
</label>
