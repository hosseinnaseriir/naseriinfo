---
interface Props {
  id: string;
  label: string;
  required?: boolean;
}

const { id, label, required = false } = Astro.props;
---

<label for={id} class="flex w-full cursor-pointer items-start gap-2.5 text-sm leading-snug text-text-muted">
  <input
    id={id}
    name={id}
    type="checkbox"
    required={required}
    class="mt-0.5 size-4 shrink-0 rounded border border-border accent-primary"
  />
  <span>{label}</span>
</label>
