---
import Link from "./Link.astro";
import Icon from "../icon/Icon.astro";

interface Props {
  href: string;
  icon: string;
  label: string;
}

const { href, icon, label } = Astro.props;
const isEmail = label === "Email";
---

<Link href={href} variant="social" ariaLabel={label} external={!isEmail}>
  <Icon name={icon} class="inline-flex size-[1.125rem] [&_svg]:size-full" />
</Link>
