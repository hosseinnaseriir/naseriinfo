---
interface Props {
  href: string;
  variant?: "default" | "social" | "toolbar" | "card" | "unstyled";
  external?: boolean;
  ariaLabel?: string;
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  variant = "default",
  external,
  ariaLabel,
  class: className = "",
  ...rest
} = Astro.props;

const isMailto = href.startsWith("mailto:");
const isHttp = href.startsWith("http");
const openInNewTab = !isMailto && (external ?? isHttp);

const variants = {
  default: "text-inherit no-underline",
  social:
    "social-link inline-flex size-9 items-center justify-center rounded-sm text-text-muted no-underline transition-[color,background-color] duration-150 ease-in-out hover:bg-primary/10 hover:text-primary",
  toolbar: "toolbar-btn no-underline",
  card: "block text-inherit no-underline transition-colors duration-150 hover:text-primary",
  unstyled: ""
};
---

<a
  href={href}
  class={`${variants[variant]} ${className}`.trim()}
  target={openInNewTab ? "_blank" : undefined}
  rel={openInNewTab ? "noopener noreferrer" : undefined}
  aria-label={ariaLabel}
  {...rest}
>
  <slot />
</a>
