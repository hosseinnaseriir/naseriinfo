---
interface Props {
  name: string;
  class?: string;
}

const { name, class: className = "icon" } = Astro.props;

const icons = import.meta.glob("../../../assets/icons/tech/*.svg", {
  query: "?raw",
  import: "default",
  eager: true
});

const iconKey = `../../../assets/icons/tech/${name}.svg`;
const svg = icons[iconKey];

if (!svg) {
  throw new Error(`Tech icon not found: ${name}`);
}
---

<span class={className} set:html={svg} />
