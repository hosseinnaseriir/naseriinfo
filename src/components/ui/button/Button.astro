---
import Link from "../link/Link.astro";

interface Props {
  href?: string;
  type?: "button" | "submit";
  variant?: "primary" | "secondary" | "ghost";
  class?: string;
  [key: string]: unknown;
}

const { href, type = "button", variant = "primary", class: className = "", ...rest } = Astro.props;

const variants = {
  primary: "border-primary bg-primary text-primary-contrast hover:opacity-90",
  secondary: "border-border bg-surface text-text hover:bg-hover",
  ghost: "border-transparent bg-transparent text-text hover:bg-hover"
};

const base =
  "inline-flex items-center justify-center rounded-md border px-4 py-2 transition-[opacity,background-color,border-color,color] duration-150 ease-in-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50";
const classes = `${base} ${variants[variant]} ${className}`;
---

{href ? (
  <Link href={href} variant="unstyled" class={classes} external={false} {...rest}>
    <slot />
  </Link>
) : (
  <button type={type} class={classes} {...rest}>
    <slot />
  </button>
)}
