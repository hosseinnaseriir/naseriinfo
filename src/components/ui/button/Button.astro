---
interface Props {
  href?: string;
  type?: "button" | "submit";
  variant?: "primary" | "secondary" | "ghost";
  class?: string;
  [key: string]: unknown;
}

const { href, type = "button", variant = "primary", class: className = "", ...rest } = Astro.props;

const variants = {
  primary: "bg-[var(--color-primary)] text-[var(--color-primary-contrast)] border-[var(--color-primary)] hover:opacity-90",
  secondary: "bg-[var(--color-surface)] text-[var(--color-text)] border-[var(--color-border)] hover:bg-gray-50",
  ghost: "bg-transparent text-[var(--color-text)] border-transparent hover:bg-gray-100"
};

const base = "inline-flex items-center justify-center rounded-md border px-4 py-2 transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-500";
---

{href ? (
  <a href={href} class={`${base} ${variants[variant]} ${className}`} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={`${base} ${variants[variant]} ${className}`} {...rest}>
    <slot />
  </button>
)}
