---
interface Props {
  as?: "h1" | "h2" | "h3" | "p" | "span";
  variant?: "headline" | "body1" | "body2" | "button" | "caption";
  class?: string;
  [key: string]: unknown;
}

const { as = "p", variant = "body1", class: className = "", ...rest } = Astro.props as Props;
const Tag = as;
const classes = {
  headline: "typography--headline",
  body1: "typography--body1",
  body2: "typography--body2",
  button: "typography--button",
  caption: "typography--caption"
};
---

<Tag class={`${classes[variant]} ${className}`} {...rest}>
  <slot />
</Tag>
