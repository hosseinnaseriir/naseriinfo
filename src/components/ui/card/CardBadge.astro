---
type CardBadgeTone = "success" | "primary" | "neutral";

interface Props {
  tone?: CardBadgeTone;
  pulse?: boolean;
  hideLabelOnMobile?: boolean;
  accessibleLabel?: string;
  class?: string;
}

const {
  tone = "success",
  pulse = true,
  hideLabelOnMobile = false,
  accessibleLabel,
  class: className = ""
} = Astro.props as Props;

const toneClasses: Record<CardBadgeTone, string> = {
  success: "border-success/35 bg-success/10 text-success-muted",
  primary: "border-primary/35 bg-primary/10 text-primary",
  neutral: "border-border bg-text-muted/10 text-text-muted"
};

const dotClasses: Record<CardBadgeTone, string> = {
  success: "bg-success",
  primary: "bg-primary",
  neutral: "bg-text-muted"
};

const classes = [
  "absolute top-3 end-3 z-1 inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-[0.7rem] font-semibold leading-tight tracking-wide",
  toneClasses[tone],
  hideLabelOnMobile ? "max-md:p-1.5 max-md:[&_.card-badge__label]:hidden" : "",
  className
]
  .filter(Boolean)
  .join(" ");
---

<span class={classes} aria-label={hideLabelOnMobile ? accessibleLabel : undefined}>
  <span
    class:list={["card-badge__dot size-[0.45rem] rounded-full", dotClasses[tone], pulse && "animate-card-badge-pulse"]}
    aria-hidden="true"
  ></span>
  <span class="card-badge__label"><slot /></span>
</span>
