---
import Card from "./Card.astro";
import CardContent from "./CardContent.astro";
import Link from "../link/Link.astro";
import ArticlePlatformBadge from "./ArticlePlatformBadge.astro";

interface Props {
  title: string;
  description: string;
  href: string;
  platform: "medium" | "linkedin" | "virgool" | "x" | "devto";
  platformLabel: string;
  publishedAt?: string;
}

const { title, description, href, platform, platformLabel, publishedAt } = Astro.props;
---

<Card as="article" padding="md" class="h-full">
  <CardContent class="h-full">
    <Link href={href} variant="unstyled" class="flex h-full flex-col gap-3 text-inherit no-underline" external={true}>
      <div class="flex items-start justify-between gap-3">
        <ArticlePlatformBadge label={platformLabel} platform={platform} />
        {publishedAt ? <time class="shrink-0 text-xs text-text-muted" datetime={publishedAt}>{publishedAt}</time> : null}
      </div>

      <div class="min-w-0 flex-1 transition-colors duration-150 hover:text-primary">
        <h3 class="text-lg font-semibold leading-snug">{title}</h3>
        <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-text-muted md:text-base">{description}</p>
      </div>
    </Link>
  </CardContent>
</Card>
