---
interface Props {
  title: string;
  excerpt: string;
  date: string;
  href: string;
}

const { title, excerpt, date, href } = Astro.props;
---

<article class="surface p-4">
  <a href={href} class="block space-y-2 no-underline">
    <h3 class="text-xl font-semibold">{title}</h3>
    <p class="text-sm text-[var(--color-text-muted)]">{date}</p>
    <p class="text-base text-[var(--color-text)]">{excerpt}</p>
  </a>
</article>
