---
type CardTag = "article" | "div" | "section";
type CardPadding = "none" | "sm" | "md" | "lg";

interface Props {
  as?: CardTag;
  padding?: CardPadding;
  interactive?: boolean;
  class?: string;
  id?: string;
}

const {
  as = "div",
  padding = "md",
  interactive = true,
  class: className = "",
  id
} = Astro.props as Props;

const Tag = as;

const paddingClass: Record<CardPadding, string> = {
  none: "",
  sm: "p-4",
  md: "p-5",
  lg: "p-6"
};

const interactiveClass = interactive
  ? [
      "transition-[border-color,box-shadow,transform] duration-200 ease-in-out",
      "before:pointer-events-none before:absolute before:inset-0 before:content-['']",
      "before:bg-gradient-to-br before:from-primary/10 before:to-transparent",
      "before:opacity-0 before:transition-opacity before:duration-200",
      "hover:-translate-y-0.5 hover:border-primary/35 hover:shadow-md hover:before:opacity-100"
    ].join(" ")
  : "";

const classes = ["surface relative overflow-hidden", paddingClass[padding], interactiveClass, className]
  .filter(Boolean)
  .join(" ");
---

<Tag class={classes} id={id}>
  <slot />
</Tag>
