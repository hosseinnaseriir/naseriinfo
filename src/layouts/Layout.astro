---
import "../styles/global.css";
import { LAYOUT_CONTENT } from "../assets/contents/common/layout";
import { getContent } from "../lib/content/ui-text";
import { localeConfig, type Locale } from "../i18n/config";

interface Props {
	title?: string;
	description?: string;
	locale?: Locale;
	path?: string;
}

const { title, description, locale = "en", path } = Astro.props as Props;
const layoutContent = getContent(LAYOUT_CONTENT, locale);
const resolvedTitle = title ?? layoutContent.defaultTitle;
const resolvedDescription = description ?? layoutContent.defaultDescription;
const dir = localeConfig[locale].dir;
const defaultPath = path ?? Astro.url.pathname;
const canonical = Astro.site ? new URL(defaultPath, Astro.site).toString() : null;
const alternates = Astro.site
	? [
			{ hreflang: "en", href: new URL(`/en${defaultPath.replace(/^\/(en|fa)/, "")}`, Astro.site).toString() },
			{ hreflang: "fa", href: new URL(`/fa${defaultPath.replace(/^\/(en|fa)/, "")}`, Astro.site).toString() },
			{ hreflang: "x-default", href: new URL("/en", Astro.site).toString() }
		]
	: [];
---

<!doctype html>
<html lang={locale} dir={dir} data-theme="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="color-scheme" content="dark light" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={resolvedDescription} />
		<meta property="og:locale" content={locale === "fa" ? "fa_IR" : "en_US"} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={resolvedTitle} />
		<meta property="og:description" content={resolvedDescription} />
		{canonical && <link rel="canonical" href={canonical} />}
		{alternates.map((item) => <link rel="alternate" hreflang={item.hreflang} href={item.href} />)}
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700&family=Vazirmatn:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{resolvedTitle}</title>
		<script is:inline>
			(() => {
				const stored = localStorage.getItem("theme");
				const theme = stored === "light" || stored === "dark" ? stored : "dark";
				document.documentElement.setAttribute("data-theme", theme);
			})();
		</script>
	</head>
	<body>
		<slot />
		<script>
			const root = document.documentElement;
			const toggle = document.querySelector("[data-theme-toggle]");

			const applyTheme = (theme) => {
				root.setAttribute("data-theme", theme);
				localStorage.setItem("theme", theme);
			};

			toggle?.addEventListener("click", () => {
				const next = root.getAttribute("data-theme") === "dark" ? "light" : "dark";
				applyTheme(next);
			});
		</script>
	</body>
</html>
