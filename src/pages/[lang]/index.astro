---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/ui/layout/Container.astro";
import Stack from "../../components/ui/layout/Stack.astro";
import HeroSection from "../../components/pages/home/HeroSection.astro";
import ServicesSection from "../../components/pages/home/ServicesSection.astro";
import ArticlesSection from "../../components/pages/home/ArticlesSection.astro";
import ContactSection from "../../components/pages/home/ContactSection.astro";
import IntroPopup from "../../components/pages/home/IntroPopup.astro";
import { HOME_PAGE_CONTENT } from "../../assets/contents/pages/home/index";
import { getContent } from "../../lib/content/ui-text";
import { getArticles } from "../../lib/content/articles";
import { locales, type Locale } from "../../i18n/config";

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const pageContent = getContent(HOME_PAGE_CONTENT, lang);
const articles = getArticles(lang);
---

<Layout locale={lang} title={pageContent.title} description={pageContent.description}>
  <Container as="main" class="py-4 md:py-6">
    <Stack gap="lg">
      <HeroSection lang={lang} />
      <ServicesSection lang={lang} />
      <ArticlesSection lang={lang} articles={articles} />
      <ContactSection lang={lang} />
    </Stack>
  </Container>

  <IntroPopup lang={lang} />
</Layout>
