---
import Layout from "../../../layouts/Layout.astro";
import Container from "../../../components/ui/layout/Container.astro";
import Typography from "../../../components/ui/typography/Typography.astro";
import ArticleCard from "../../../components/ui/card/ArticleCard.astro";
import { locales, type Locale } from "../../../i18n/config";
import { getArticles } from "../../../lib/content/articles";

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const isFa = lang === "fa";
const articles = await getArticles(lang);
---

<Layout
  locale={lang}
  title={isFa ? "مقالات" : "Articles"}
  description={isFa ? "آرشیو مقالات فارسی." : "Article archive in English."}
>
  <Container as="main" class="py-12">
    <Typography as="h1" variant="headline" class="mb-6">{isFa ? "مقالات" : "Articles"}</Typography>
    {articles.length > 0 ? (
      <div class="grid gap-4">
        {articles.map((article) => (
          <ArticleCard
            title={article.title}
            date={article.publishedAt}
            excerpt={article.excerpt}
            href={`/${lang}/articles/${article.slug}`}
          />
        ))}
      </div>
    ) : (
      <p class="surface p-4 text-[var(--color-text-muted)]">{isFa ? "هنوز مقاله‌ای منتشر نشده است." : "No articles published yet."}</p>
    )}
  </Container>
</Layout>
