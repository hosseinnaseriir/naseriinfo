---
import Layout from "../../../layouts/Layout.astro";
import SiteToolbar from "../../../components/layout/SiteToolbar.astro";
import Container from "../../../components/ui/layout/Container.astro";
import Typography from "../../../components/ui/typography/Typography.astro";
import ArticleCard from "../../../components/ui/card/ArticleCard.astro";
import { ARTICLES_PAGE_CONTENT } from "../../../assets/contents/pages/articles/index";
import { getContent } from "../../../lib/content/ui-text";
import { locales, type Locale } from "../../../i18n/config";
import { getArticles } from "../../../lib/content/articles";

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const content = getContent(ARTICLES_PAGE_CONTENT, lang);
const articles = await getArticles(lang);
---

<Layout locale={lang} title={content.title} description={content.description}>
  <SiteToolbar locale={lang} path={Astro.url.pathname} variant="fixed" />
  <Container as="main" class="py-4 md:py-6">
    <Typography as="h1" variant="headline" class="mb-6">{content.title}</Typography>
    {articles.length > 0 ? (
      <div class="grid gap-4">
        {articles.map((article) => (
          <ArticleCard
            title={article.title}
            date={article.publishedAt}
            excerpt={article.excerpt}
            href={`/${lang}/articles/${article.slug}`}
          />
        ))}
      </div>
    ) : (
      <p class="rounded-md border border-border bg-surface p-4 text-text-muted">{content.empty}</p>
    )}
  </Container>
</Layout>
