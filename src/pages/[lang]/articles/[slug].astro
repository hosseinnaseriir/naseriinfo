---
import { getCollection, render } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import SiteToolbar from "../../../components/layout/SiteToolbar.astro";
import Container from "../../../components/ui/layout/Container.astro";
import BackLink from "../../../components/ui/link/BackLink.astro";
import { ARTICLES_PAGE_CONTENT } from "../../../assets/contents/pages/articles/index";
import { getContent } from "../../../lib/content/ui-text";
import { locales, type Locale } from "../../../i18n/config";

export async function getStaticPaths() {
  const posts = await getCollection("articles");
  return posts
    .filter((post) => locales.includes(post.data.locale))
    .map((post) => ({
      params: { lang: post.data.locale, slug: post.id.replace(/\.md$/, "") },
      props: { post }
    }));
}

const { post } = Astro.props;
const lang = Astro.params.lang as Locale;
const content = getContent(ARTICLES_PAGE_CONTENT, lang);
const { Content } = await render(post);
---

<Layout
  locale={lang}
  title={post.data.title}
  description={post.data.excerpt}
>
  <SiteToolbar locale={lang} path={Astro.url.pathname} variant="fixed" />
  <Container as="main" class="py-4 md:py-6">
    <BackLink href={`/${lang}/articles`} label={content.backToArticles} class="mb-4" />
    <article class="mx-auto max-w-3xl rounded-md border border-border bg-surface p-6 md:p-8">
      <p class="mb-2 text-sm text-text-muted">{post.data.publishedAt}</p>
      <h1 class="mb-5 text-3xl font-semibold">{post.data.title}</h1>
      <div class="prose prose-slate max-w-none">
        <Content />
      </div>
    </article>
  </Container>
</Layout>
